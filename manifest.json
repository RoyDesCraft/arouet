{
  "manifest_version": 3,
  "name": "Arouet",
  "version": "1.0.0",
  "description": "Mémorise et rejoue automatiquement les bonnes réponses sur Projet Voltaire.",

  "permissions": ["storage"],

  "content_scripts": [
    {
      "matches": ["https://*.projet-voltaire.fr/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],

  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "48": "icons/icon48.png"
    }
  },

  "icons": {
    "48": "icons/icon48.png"
  }
}
